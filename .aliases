function mv-ln-s {
  mv "${1}" "${2}" && ln -s "${2}"/"${1}"
}

function coredumpctl-dbg-last {
  coredumpctl list
  # Get the last coredump ID (PID column, which is after the timestamp)
  local last_coredump_id=$(coredumpctl list | tail -n 1 | awk '{print $5}')
  echo "Debugging coredump ID: $last_coredump_id"
  coredumpctl debug "$last_coredump_id"
}

source /home/jberlanga/Code/stg-nvim/stg-aliases.bash

# Uncommit all commits since the upstream divergence point, turning them into StGit patches.
# Usage: stg-uncommit-n [upstream-ref]
# If no ref given, tries: open PR base branch (via gpp strategy) → @{upstream} →
# upstream/* branch with the most recent merge-base to HEAD.
function stg-uncommit-n {
  local upstream_ref count
  if [[ -n "$1" ]]; then
    upstream_ref="$1"
    if ! git rev-parse --verify "$upstream_ref" &>/dev/null; then
      echo "Error: '$upstream_ref' does not exist."
      return 1
    fi
  else
    if _git-pr-resolve-branch &>/dev/null; then
      local pr_branch="$_GIT_PR_BRANCH"
      local best_pr_upstream="" best_pr_count=999999999
      local r url gh_repo base_ref c
      for r in $(git remote); do
        url=$(git remote get-url "$r")
        gh_repo=$(echo "$url" | sed -n 's|.*github\.com[:/]\([^/]*/[^/.]*\)\(\.git\)\?$|\1|p')
        [[ -z "$gh_repo" ]] && continue
        base_ref=$(gh pr list -R "$gh_repo" -L 500 --json headRefName,baseRefName \
          --jq '.[] | select(.headRefName=="'"$pr_branch"'") | .baseRefName' 2>/dev/null)
        [[ $? -ne 0 ]] && continue
        [[ -z "$base_ref" ]] && continue
        if git rev-parse --verify "refs/remotes/$r/$base_ref" &>/dev/null; then
          c=$(git rev-list --count "refs/remotes/$r/$base_ref..HEAD" 2>/dev/null)
          if [[ "$c" -lt "$best_pr_count" ]]; then
            best_pr_count="$c"
            best_pr_upstream="refs/remotes/$r/$base_ref"
          fi
        fi
      done
      if [[ -n "$best_pr_upstream" ]]; then
        upstream_ref="$best_pr_upstream"
        echo "PR '$pr_branch' targets ${upstream_ref#refs/remotes/} ($best_pr_count commits ahead)"
      fi
    fi
    if [[ -z "$upstream_ref" ]]; then
      upstream_ref=$(git rev-parse --abbrev-ref @{upstream} 2>/dev/null)
    fi
    if [[ -z "$upstream_ref" ]]; then
      local best_ref best_base_ts=0
      local ref base ts
      for ref in $(git for-each-ref --format='%(refname:short)' refs/remotes/upstream/); do
        base=$(git merge-base HEAD "$ref" 2>/dev/null) || continue
        ts=$(git log -1 --format='%ct' "$base")
        if [[ "$ts" -gt "$best_base_ts" ]]; then
          best_base_ts="$ts"
          best_ref="$ref"
        fi
      done
      if [[ -z "$best_ref" ]]; then
        echo "Error: no upstream/* branch shares history with HEAD."
        return 1
      fi
      upstream_ref="$best_ref"
    fi
  fi
  count=$(git rev-list --count "$upstream_ref..HEAD")
  if [[ "$count" -eq 0 ]]; then
    echo "No commits ahead of $upstream_ref."
    return 0
  fi
  echo "Found $count commit(s) ahead of $upstream_ref:"
  git log --oneline "$upstream_ref..HEAD"
  echo -n "Run 'stg uncommit -n $count'? [y/N] "
  read -r ans
  if [[ "$ans" =~ ^[Yy]$ ]]; then
    stg uncommit -n "$count"
  else
    echo "Cancelled."
  fi
}

# Create symlinks for several files at once
function ln-s-glob {
  for file in $@; do
    ln -s "$file"
  done
}

# sorted
function git-branch {
 git for-each-ref --sort=-committerdate refs/heads/ --format='%(committerdate:short) %(refname:short)' | head -n 10
}

function git-exclude {
 echo "${1}" >> .git/info/exclude
}


  # Resolve the current user's PR branch.
  # Sets _GIT_PR_BRANCH on success; prints diagnostics and returns 1 on failure.
  # Usage: _git-pr-resolve-branch [explicit-branch]
function _git-pr-resolve-branch {
    _GIT_PR_BRANCH=""
    local username current_branch branch matches count
    username=$(gh api user --jq .login 2>/dev/null)
    if [[ -z "$username" ]]; then
      echo "Could not determine GitHub username."
      return 1
    fi
    current_branch=$(git branch --show-current 2>/dev/null)
    [[ -n "$GPP_DEBUG" ]] && echo "[debug] username='$username'"
    [[ -n "$GPP_DEBUG" ]] && echo "[debug] current_branch='$current_branch'"
    matches=$(gh pr list -L 500 --json headRefName,author --jq \
      '.[] | select(.author.login=="'"$username"'") | .headRefName')
    [[ -n "$GPP_DEBUG" ]] && echo "[debug] matches='$matches'"
    count=$(echo "$matches" | grep -c .)
    [[ -n "$GPP_DEBUG" ]] && echo "[debug] count=$count"
    if [[ $count -eq 0 ]]; then
      echo "No PR branch for user '$username' found."
      return 1
    elif [[ $count -gt 1 ]]; then
      if [[ -n "$1" ]]; then
        if echo "$matches" | grep -Fxq "$1"; then
          branch="$1"
        else
          echo "Branch '$1' is not one of your PR branches:"
          echo "$matches"
          return 1
        fi
      else
        echo "Multiple PR branches for user '$username' found:"
        echo "$matches"
        if [[ -n "$current_branch" && ${#current_branch} -gt 1 ]]; then
          local branch_without_num=$(echo "$current_branch" | sed 's/[0-9]*$//')
          [[ -n "$GPP_DEBUG" ]] && echo "[debug] branch_without_num='$branch_without_num'"
          if [[ "$branch_without_num" != "$current_branch" ]] && echo "$matches" | grep -Fxq "$branch_without_num"; then
            branch="$branch_without_num"
            echo "Using PR branch matching current without trailing number: $branch"
          fi
        fi
        if [[ -z "$branch" ]]; then
          branch=$(gh pr list --json headRefName,author,updatedAt --jq \
            '.[] | select(.author.login=="'"$username"'") | [.headRefName, .updatedAt] | @tsv' \
            | sort -k2 -r | head -n1 | cut -f1)
          if [[ -z "$branch" ]]; then
            echo "Could not determine most recent PR branch for user '$username'."
            return 1
          fi
          echo "Picking most recent: $branch"
        fi
      fi
    else
      branch="$matches"
    fi
    _GIT_PR_BRANCH="$branch"
}

  # Usage: git-pr-push [-y] [branch]
  # Finds your PR and pushes HEAD to it (force-with-lease). Prefers a PR whose branch
  # is the current branch name without the last character (e.g. ...-cpp3 -> ...-cpp), then
  # falls back to exact match or most recently updated.
function git-pr-push {
    _git-pr-resolve-branch "$1" || return 1
    local branch="$_GIT_PR_BRANCH"
    echo "Pushing HEAD to origin $branch (force-with-lease)..."
    local confirm
    if [[ " $@ " =~ " -y " ]]; then
      confirm="y"
    else
      echo -n "Are you sure you want to push HEAD to origin $branch with --force-with-lease? [y/N] "
      read confirm
    fi
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
      git push origin HEAD:"$branch" --force-with-lease
    else
      echo "Push cancelled."
    fi
}

alias gpp='git-pr-push'

  # Usage: git-pr-open [branch]
  # Opens the PR URL in the default browser.
function git-pr-open {
    _git-pr-resolve-branch "$1" || return 1
    local branch="$_GIT_PR_BRANCH"
    local username url
    username=$(gh api user --jq .login 2>/dev/null)
    url=$(gh pr list -L 500 --json headRefName,url,author --jq \
      '.[] | select(.author.login=="'"$username"'" and .headRefName=="'"$branch"'") | .url')
    if [[ -z "$url" ]]; then
      echo "Could not find PR URL for branch '$branch'."
      return 1
    fi
    echo "Opening $url"
    xdg-open "$url"
}

alias gpo='git-pr-open'

# print current commit hash
function git-log-h1 {
	git log | head -n 1 | awk '{print $NF}'
}

function git-log-n {
  _n="$1"
  git log -n "$_n" --pretty=%H | tee commits.txt
}

function cherry-pick-commits {
 tac commits.txt | xargs git cherry-pick -m 1 --allow-empty
}

# requires:  brew install clang-format@20 && apt install clang-format-19
function clangfh-diff {
 git-clang-format-19 --diff HEAD^ --extensions h,hh,hpp,c,cc,cpp
}
function clangfh {
 git-clang-format-19 HEAD^ --extensions h,hh,hpp,c,cc,cpp
}
function clangf-diff {
 git-clang-format-19 --diff $1 --extensions h,hh,hpp,c,cc,cpp
}

function clangf {
 git-clang-format-19 $1 --extensions h,hh,hpp,c,cc,cpp
}

# mark as resolved all git conflict
function git-resolve {
	git status --short | grep '^UU' | awk '{print $2}' | xargs git add
}

function git-resolve-cherry-pick {
	local root
	root=$(git rev-parse --show-toplevel) || return 1
	git diff --name-only --diff-filter=U -z | xargs -0 -I{} git add "$root/{}" && git cherry-pick --continue
}

# TODO: check if bear is available  
function cmake-build {
	bear --append -- cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -S . -B build ${@:2} && bear --append -- cmake --build build -j8
}

function bare-make-build-debug {
	bear --append -- bare-make generate -D CMAKE_EXPORT_COMPILE_COMMANDS=ON -D CMAKE_BUILD_TYPE=Debug ${@:1} && bear --append -- bare-make build 
}

function cmake-build-debug {
	bear --append -- cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DCMAKE_BUILD_TYPE=Debug -S . -B build ${@:2} && bear --append -- cmake --build build -j 8
}

function cmake-vcpkg-build-debug { 
	bear --append -- cmake -S . -B build -DCMAKE_TOOLCHAIN_FILE=/opt/vcpkg/scripts/buildsystems/vcpkg.cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DCMAKE_BUILD_TYPE=Debug ${@:2} && bear --append -- cmake --build build -j 8 
}

function cmake-build-debug {
bear --append -- cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DCMAKE_BUILD_TYPE=Debug -S . -B build ${@:2} && bear --append -- cmake --build build -j 8
}


function cmake-run {
bear --append -- cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -S . -B build ${@:2} && bear --append -- cmake --build build --target "$1" -j8 --verbose && "./build/$1"
}

function cmake-help {
bear --append -- cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -S . -B build ${@:2} && cmake --build build --target help
}

