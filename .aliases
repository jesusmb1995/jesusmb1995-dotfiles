#!/bin/bash

alias j='jump $0'
alias p='echo $PWD | xclip -selection clipboard'
alias tb='tmux show-buffer -b $(tmux list-buffers | head -n 1 | cut -d: -f1) | xclip -selection clipboard'
alias nvimf='NVIM_MINIMAL= nvim'

# TODO create PR

# Note:  gh repo set-default <target>
# Should be set with target repo (not our fork)
function pr {
  if [[ -n "$1" && -n "$2" ]]; then
    gh pr create --draft --repo "$1" --base "$2"
  elif [[ -n "$1" ]]; then
    gh pr create --draft --repo "$1"
  else
    gh pr create --draft
  fi
}

alias temp-notes='vim $HOME/Documents/notes/tmp_notes.txt'
alias aliases='vim $HOME/.aliases'

function gh-clone-branch {
  if [[ $# -lt 3 ]]; then
    echo "Usage: gh-clone-branch <user> <repo> <branch> [other git args]"
    return 1
  fi
  gh repo clone "${1}/${2}" -- --single-branch --branch="${3}" ${@:4}
  cd "${2}"
}

